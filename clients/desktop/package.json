{
  "name": "omni-context-desktop",
  "version": "0.0.18",
  "description": "OmniContext Desktop - Zero-telemetry coding assistant",
  "main": "./out/main/index.js",
  "author": "bluenoah1991",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "node build.mjs",
    "install:cn": "ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npm install",
    "postinstall": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ electron-builder install-app-deps && cd cli-deps && npm install",
    "package": "npm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --dir",
    "package:win": "npm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win",
    "package:mac": "npm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --mac zip"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "selfsigned": "^2.4.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.27.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.omni-context.desktop",
    "productName": "OmniContext Desktop",
    "directories": {
      "buildResources": "../../assets"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../../dist",
        "to": "omni-context-cli",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "cli-deps/node_modules",
        "to": "omni-context-cli/node_modules"
      },
      {
        "from": "webview",
        "to": "webview",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "out/portal",
        "to": "portal",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "out/office-dist",
        "to": "office-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../assets/cone@256.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../../assets/cone@256.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "OmniContext Desktop"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "../../assets/cone-mac@512.png"
    }
  }
}
