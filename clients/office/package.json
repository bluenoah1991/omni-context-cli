{
  "name": "omnicontext-office",
  "version": "0.0.1",
  "description": "Connect Microsoft Office to OmniContext CLI",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "certs": "office-addin-dev-certs install",
    "sideload": "office-addin-dev-settings sideload manifest.xml",
    "unsideload": "office-addin-dev-settings unregister manifest.xml",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-dev-settings": "^3.0.6",
    "@types/office-js": "^1.0.421",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "copy-webpack-plugin": "^13.0.1",
    "html-webpack-plugin": "^5.6.4",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
