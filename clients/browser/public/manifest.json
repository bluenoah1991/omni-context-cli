{
  "manifest_version": 3,
  "name": "OmniContext Connect",
  "version": "0.0.14",
  "description": "Connect your browser to OmniContext CLI",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open OmniContext"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "sidePanel",
    "bookmarks",
    "history",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
